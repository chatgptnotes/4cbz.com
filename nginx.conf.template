# =========================================
# Nginx Configuration for 4cbz.com
# =========================================
# Copy this configuration to aaPanel:
# Website > 4cbz.com > Settings > Configuration File

server {
    listen 80;
    listen 443 ssl http2;
    server_name 4cbz.com www.4cbz.com;

    # =====================================
    # SSL Configuration (added by aaPanel)
    # =====================================
    # These lines will be automatically added when you setup SSL in aaPanel
    # ssl_certificate /www/server/panel/vhost/cert/4cbz.com/fullchain.pem;
    # ssl_certificate_key /www/server/panel/vhost/cert/4cbz.com/privkey.pem;
    # ssl_protocols TLSv1.2 TLSv1.3;
    # ssl_ciphers HIGH:!aNULL:!MD5;
    # ssl_prefer_server_ciphers on;

    # =====================================
    # Root Directory
    # =====================================
    # Frontend static files location
    root /www/wwwroot/4cbz.com/4Cbitz_frontend/dist;
    index index.html;

    # =====================================
    # Security Headers
    # =====================================
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # =====================================
    # Gzip Compression
    # =====================================
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/x-javascript
        application/xml+rss
        application/javascript
        application/json
        image/svg+xml;

    # =====================================
    # API Reverse Proxy to Backend
    # =====================================
    # Routes all /api/* requests to Node.js backend on port 5001
    location /api/ {
        # Proxy to backend
        proxy_pass http://127.0.0.1:5001/api/;
        proxy_http_version 1.1;

        # Preserve original request information
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # WebSocket support (if needed for future features)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Disable buffering for better real-time performance
        proxy_buffering off;
        proxy_request_buffering off;

        # Handle large file uploads (adjust if needed)
        client_max_body_size 100M;
    }

    # =====================================
    # Frontend - React SPA Routing
    # =====================================
    # Serve static files and handle client-side routing
    location / {
        # Try to serve file directly, fallback to index.html for SPA routing
        try_files $uri $uri/ /index.html;

        # Cache control for HTML files (no cache for index.html to ensure updates)
        location = /index.html {
            add_header Cache-Control "no-cache, no-store, must-revalidate";
            add_header Pragma "no-cache";
            add_header Expires "0";
        }

        # Cache static assets (JS, CSS, images, fonts)
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|otf|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        # Cache JSON files
        location ~* \.json$ {
            expires 1h;
            add_header Cache-Control "public, must-revalidate";
        }
    }

    # =====================================
    # Security: Block Hidden Files
    # =====================================
    # Prevent access to .env, .git, etc.
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # =====================================
    # Security: Block Common Attack Patterns
    # =====================================
    location ~* (\.php|\.asp|\.aspx|\.jsp)$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # =====================================
    # File Upload Size Limit
    # =====================================
    client_max_body_size 100M;
    client_body_buffer_size 128k;

    # =====================================
    # Logging
    # =====================================
    access_log /www/wwwlogs/4cbz.com.log;
    error_log /www/wwwlogs/4cbz.com.error.log;

    # Disable logging for static assets (optional - reduces log size)
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        access_log off;
    }

    # =====================================
    # Error Pages (optional)
    # =====================================
    # error_page 404 /404.html;
    # error_page 500 502 503 504 /50x.html;
}

